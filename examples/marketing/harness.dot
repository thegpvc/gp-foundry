// A marketing-site content harness — proves the compiler is domain-general.
// Same node types, same compiler, same runtime core as the software harness;
// only the roles, gates, and the human publish-gate differ.
// `type` = mechanical GitHub interaction; `role` = the job description (content).
// Mirrors docs/plans/2026-07-01-gp-foundry-system-design.md §3.5.
digraph marketing {
  // ── nodes: type = handler, role = job-description (referenced, never inlined) ──
  start       [type=start]
  brief       [type=issue-agent, role="roles/content/brief-triager.md", context=issue, output=comment]  // shape a content request
  writer      [type=producer,    role="roles/content/copywriter.md",    context=issue]                   // draft landing-page copy in a PR
  brand       [type=pr-review,   role="roles/content/brand-critic.md",  context="pr-diff", gates="linkcheck.yml,spellcheck.yml"]  // review tone/brand, post a verdict
  editor      [type=pr-fix,      role="roles/content/editor.md",        max_attempts=2]                  // address brand feedback
  publish     [type=human-gate,  environment=production]                                                 // brand sign-off before go-live
  needs_human [type=exit]

  // ── edges: on = GitHub event, when = GitHub-observable guard ──
  start  -> brief       [on="issues.opened"]
  brief  -> writer      [when="label=content"]
  writer -> brand       [on="pull_request.opened"]
  brand  -> publish     [when="verdict=approve"]
  brand  -> editor      [when="verdict=request_changes"]
  editor -> brand       [on="push"]                    // retry loop
  editor -> needs_human [when="attempts>=2"]           // bounded escape (required on every loop)
}
