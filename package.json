{
  "name": "gp-foundry",
  "version": "0.0.0",
  "private": true,
  "description": "Compile a directed-graph spec (harness.dot) into an autonomous GitHub Actions agent harness.",
  "type": "module",
  "bin": {
    "gp-foundry": "./dist/cli/index.cjs"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "cli": "tsx src/cli/index.ts",
    "build": "tsup",
    "build:actions": "tsup --config tsup.actions.config.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:dist": "npm run build:actions && git diff --exit-code -- 'actions/**/dist/**'"
  },
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/github": "^6.0.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "commander": "^12.1.0",
    "js-yaml": "^4.1.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.2",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
