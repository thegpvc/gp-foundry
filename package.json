{
  "name": "@thegpvc/gp-foundry",
  "version": "0.1.0",
  "description": "Compile a directed-graph spec (harness.dot) into an autonomous GitHub Actions agent harness.",
  "type": "module",
  "license": "MIT",
  "author": "The General Partnership (https://thegp.com)",
  "homepage": "https://github.com/thegpvc/gp-foundry#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thegpvc/gp-foundry.git"
  },
  "bugs": {
    "url": "https://github.com/thegpvc/gp-foundry/issues"
  },
  "keywords": [
    "github-actions",
    "agent",
    "harness",
    "claude",
    "codegen",
    "dot",
    "graphviz",
    "automation",
    "ci",
    "workflow"
  ],
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "gp-foundry": "./dist/cli/index.cjs"
  },
  "files": [
    "dist/cli",
    "actions/*/action.yml",
    "actions/*/dist",
    "actions/*/README.md",
    "schema",
    "roles",
    "skill",
    "AGENTS.md",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "cli": "tsx src/cli/index.ts",
    "build": "tsup",
    "build:actions": "tsup --config tsup.actions.config.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:dist": "npm run build:actions && git diff --exit-code -- 'actions/**/dist/**'",
    "prepare": "npm run build"
  },
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/github": "^9.1.1",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "commander": "^12.1.0",
    "js-yaml": "^4.1.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.2",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
